{
    "name": "hexawebsystems/laravel-hexa-package-unsplash",
    "description": "Unsplash — stock photo API integration for high-resolution image search, download, and attribution.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "hexa_package_unsplash\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "hexa_package_unsplash\\Providers\\UnsplashServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
